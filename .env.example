DB_DATABASE=
DB_SSL=true
DATABASE_HOST=
DATABASE_PORT=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=

# Server
API_PORT=
JWT_SECRET=
SYNC_SECRET_KEY=
ENFORCE_HTTPS=true
# Lista de origens separadas por virgula (ex.: painel/prod)
CORS_ORIGINS=
PDF_SERVICE_URL=http://localhost:8080

# Firebase Admin
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Optional: JSON file path instead of the vars above
FIREBASE_SERVICE_ACCOUNT_PATH=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email delivery
# EMAIL_PROVIDER=brevo
# Brevo HTTP API example:
# BREVO_API_KEY=
# EMAIL_BRAND_NAME=EncontreAqui Imóveis
# EMAIL_FROM=no-reply@encontreaquiimoveis.com
# EMAIL_FROM_NAME=EncontreAqui Imoveis
# EMAIL_LOGO_URL_2X=https://cdn.exemplo.com/email/logo@2x.png
# EMAIL_VERIFICATION_SURFACE_URL=https://site-imobiliario-encontreaqui.vercel.app/verificacao
# PASSWORD_RESET_SURFACE_URL=https://site-imobiliario-encontreaqui.vercel.app/recuperar-senha
# Brevo SMTP fallback example:
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
EMAIL_PROVIDER=
EMAIL_BRAND_NAME=
EMAIL_FROM=
EMAIL_FROM_NAME=
EMAIL_LOGO_URL_2X=
EMAIL_VERIFICATION_SURFACE_URL=
PASSWORD_RESET_SURFACE_URL=
EMAIL_HTTP_TIMEOUT_MS=
BREVO_API_KEY=
BREVO_API_BASE_URL=
BREVO_FROM=
BREVO_FROM_NAME=
RESEND_API_KEY=
RESEND_API_BASE_URL=
# SMTP fallback
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_CONNECTION_TIMEOUT_MS=
SMTP_GREETING_TIMEOUT_MS=
SMTP_SOCKET_TIMEOUT_MS=
SMTP_DNS_TIMEOUT_MS=
SMTP_FAMILY=
SMTP_REQUIRE_TLS=
SMTP_IGNORE_TLS=
SMTP_TLS_SERVERNAME=
SMTP_USER=
SMTP_PASS=
