{
  "name": "imobiliaria-backend",
  "version": "1.0.0",
  "description": "API para o aplicativo imobiliário",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --exit-child --transpile-only --ignore-watch node_modules src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "node ./node_modules/vitest/vitest.mjs run --exclude tests/local-stress/**",
    "test:coverage": "node ./node_modules/vitest/vitest.mjs run --coverage --exclude tests/local-stress/** && node scripts/check-critical-coverage.cjs",
    "test:architecture": "node scripts/check-architecture-discipline.cjs",
    "test:watch": "node ./node_modules/vitest/vitest.mjs --exclude tests/local-stress/**",
    "test:local-stress:email-codes": "node ./node_modules/vitest/vitest.mjs run tests/local-stress/email-code-challenges.test.ts",
    "test:local-stress:r2-documents": "node ./node_modules/vitest/vitest.mjs run tests/local-stress/negotiation-r2-documents.test.ts",
    "ci:verify": "npm run build && npm run test:architecture && npm run test",
    "security:audit": "npm audit --audit-level=high",
    "test:sast:r2-documents": "cross-env PYTHONUTF8=1 semgrep scan --config auto src/services/negotiationDocumentStorageService.ts src/modules/negotiations/infra/NegotiationDocumentsRepository.ts src/controllers/NegotiationController.ts src/controllers/ContractController.ts src/controllers/AdminController.ts",
    "migrate:up": "ts-node src/database/migrationRunner.ts up",
    "migrate:down": "ts-node src/database/migrationRunner.ts down",
    "migrate:status": "ts-node src/database/migrationRunner.ts status",
    "db:init": "ts-node src/database/init.ts",
    "db:verify": "ts-node src/database/schemaVerification.ts",
    "sentry:test": "ts-node scripts/sentry-test.ts"
  },
  "keywords": [],
  "author": "Ctrshift-Pm",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1040.0",
    "@sentry/node": "^10.51.0",
    "@sentry/profiling-node": "^10.51.0",
    "@types/nodemailer": "^7.0.11",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.4",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.1",
    "firebase-admin": "^13.8.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "multer": "^2.1.1",
    "mysql2": "^3.22.3",
    "nodemailer": "^7.0.12",
    "prom-client": "^15.1.3",
    "punycode": "^2.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.37",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^7.0.3",
    "supertest": "^7.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18",
    "vitest-mock-extended": "^3.1.0"
  }
}
